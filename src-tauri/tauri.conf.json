{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RCJ Soccer Simulator",
  "version": "0.1.0",
  "identifier": "com.rosendo-leo.rcj-soccer-simulator",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix frontend run build:tauri",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "RCJ Soccer Simulator",
        "width": 1360,
        "height": 850,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/rcj-server"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBQjEzMDFCNzVBN0M5ODMKUldTRHlhZDFHekN4U3NkRVZjRWNFVFdqdmxiRFNqMEZWUk5ISGVYbUNhaGxaN3FuZnhlbmNvV2gK",
      "endpoints": [
        "https://github.com/Rosendo-leo/SimulatorSoccer/releases/latest/download/latest.json"
      ]
    }
  }
}
